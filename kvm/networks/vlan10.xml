<!--
  ============================================================
  VLAN 10 — Zone Bureautique (non fiable)
  ============================================================
  Réseau KVM isolé : pas de NAT, pas d'accès Internet direct.
  L'ABSENCE de balise <forward> rend ce réseau totalement isolé
  de l'hôte et d'Internet. Seules les VMs sur ce réseau
  communiquent entre elles. OPNsense fait le pont vers les
  autres VLANs.

  OPNsense (10.10.10.1) sera la passerelle et le serveur DHCP.
  Les postes clients (Win10, Kali) s'y connectent.
  ============================================================
-->
<network>
  <name>vlan10</name>
  <!-- Pas de <forward> = réseau isolé (coupé de l'hôte et d'Internet) -->
  <bridge name="virbr10" stp="off" delay="0"/>
  <ip address="10.10.10.1" netmask="255.255.255.0"/>
</network>
