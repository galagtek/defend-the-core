<!--
  ============================================================
  VLAN 30 — Zone Critique (serveurs métier, BDD)
  ============================================================
  Réseau KVM isolé (pas de <forward>).
  OPNsense (10.10.30.1) est la passerelle.
  Ubuntu Server (Web+BDD) et Windows Server (AD) s'y connectent.
  Aucun accès direct depuis le VLAN 10 (règle OPNsense block).
  ============================================================
-->
<network>
  <name>vlan30</name>
  <bridge name="virbr30" stp="off" delay="0"/>
  <ip address="10.10.30.1" netmask="255.255.255.0"/>
</network>
